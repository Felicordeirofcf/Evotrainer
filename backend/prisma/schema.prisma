// Configuração para PostgreSQL (Neon)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// MODELO DE USUÁRIO (MASTER, PERSONAL, ALUNO)
// ==========================================
model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String    @default("")
  
  // Níveis de acesso: SUPERADMIN (Você), ADMIN (Personal), STUDENT (Aluno)
  role         String    @default("STUDENT") 
  status       String    @default("Ativo") // Ativo, Bloqueado, Inadimplente
  
  // Dados do Aluno (Essencial para a IA MCP ler antes de prescrever)
  phone        String?
  age          String?
  weight       String?
  height       String?
  goal         String?   @default("Hipertrofia")
  level        String?   @default("Intermediário") // Iniciante, Intermediário, Avançado
  
  // NOVO: Campo de Anamnese focado em lesões e restrições para a IA não cometer erros
  anamnese     String?   @db.Text 
  restricoes   String?   @db.Text // Ex: "Hernia de disco L4-L5, Condromalácia"
  
  notes        String?   @db.Text
  avatar       String?   @db.Text
  streak       Int       @default(0)
  
  // Recuperação de Senha
  resetToken   String?
  resetExpires DateTime?

  // Lógica de SaaS (Para o Personal)
  plano          String    @default("GRATIS") // GRATIS, START, PRO, ELITE
  planExpiresAt  DateTime? // Data de expiração da assinatura
  iaUsadaMes     Int       @default(0)
  
  // White Label (Apenas para Plano ELITE)
  brandName    String?
  brandColor   String?   @default("#2563eb")
  brandLogo    String?   @db.Text

  // Relacionamentos Hierárquicos
  trainerId    Int?
  trainer      User?     @relation("TrainerToStudent", fields: [trainerId], references: [id])
  alunos       User[]    @relation("TrainerToStudent")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  history      WorkoutHistory[]
  workouts     WorkoutTemplate[]
}

// ==========================================
// MODELO DE FICHA DE TREINO (TEMPLATE)
// ==========================================
model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  title       String     // Ex: Treino A - Peitorais
  duration    String     // Ex: 60 min
  dayOfWeek   String?    @default("Segunda")
  
  // NOVO: Armazenar o PDF gerado para re-envio rápido
  pdfUrl      String?    @db.Text 
  
  userId      Int?       
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exercises   Exercise[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ==========================================
// MODELO DE EXERCÍCIO
// ==========================================
model Exercise {
  id           Int             @id @default(autoincrement())
  name         String
  sets         String          // Ex: 3x12 ou 4x falha
  weight       String          // Ex: 40kg ou RPE 8
  youtubeId    String?
  
  // Controle de Bi-set / Tri-set
  isConjugado  Boolean         @default(false)
  conjugadoCom String?         
  
  workoutId    Int
  workout      WorkoutTemplate @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

// ==========================================
// HISTÓRICO E FEEDBACK (O QUE O ALUNO FEZ)
// ==========================================
model WorkoutHistory {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workoutName  String
  rating       Int?     // 1 a 5 estrelas
  comment      String?  @db.Text
  
  completedAt  DateTime @default(now())
}

// ==========================================
// CONFIGURAÇÃO GLOBAL DO SISTEMA (DASHBOARD MASTER)
// ==========================================
model SystemConfig {
  id           Int      @id @default(1)
  promoActive  Boolean  @default(false)
  promoTitle   String   @default("🔥 OFERTA DE LANÇAMENTO 🔥")
  
  // Preços configuráveis pelo Master (Você)
  startPrice   String   @default("30")
  startLink    String   @default("https://www.asaas.com/c/...")
  proPrice     String   @default("60")
  proLink      String   @default("https://www.asaas.com/c/...")
  elitePrice   String   @default("100")
  eliteLink    String   @default("https://www.asaas.com/c/...")
  
  maintenance  Boolean  @default(false) // Para você travar o app se precisar
}