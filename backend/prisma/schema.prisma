// Configuração para PostgreSQL (Neon)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   @default("") 
  role      String   @default("STUDENT") 
  streak    Int      @default(0)         
  status    String   @default("Ativo")   
  phone     String?
  age       String?
  weight    String?
  height    String?
  goal      String?  @default("Hipertrofia")
  notes     String?
  avatar    String?  @db.Text
  resetToken   String?
  resetExpires DateTime?
  plano      String   @default("GRATIS")
  iaUsadaMes Int      @default(0)
  brandName  String?
  brandColor String?
  brandLogo  String?  @db.Text
  trainerId Int?
  trainer   User?    @relation("TrainerToStudent", fields: [trainerId], references: [id])
  alunos    User[]   @relation("TrainerToStudent")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  history   WorkoutHistory[]
  workouts  WorkoutTemplate[] 
}

model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  title       String
  duration    String
  dayOfWeek   String?    @default("Segunda") 
  userId      Int?       
  user        User?      @relation(fields: [userId], references: [id])
  exercises   Exercise[]
}

model Exercise {
  id          Int      @id @default(autoincrement())
  name        String
  sets        String   
  weight      String   
  youtubeId   String?  
  isConjugado  Boolean  @default(false)
  conjugadoCom String? 
  workoutId   Int
  workout     WorkoutTemplate @relation(fields: [workoutId], references: [id], onDelete: Cascade) 
}

model WorkoutHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  workoutName String
  rating      Int?
  comment     String?
  completedAt DateTime @default(now()) 
}

// NOVA TABELA PARA AS PROMOÇÕES E LINKS DO ASAAS
model SystemConfig {
  id          Int      @id @default(1)
  promoActive Boolean  @default(false)
  promoTitle  String   @default("🔥 OFERTA DE LANÇAMENTO 🔥")
  startPrice  String   @default("30")
  startLink   String   @default("https://www.asaas.com/c/gppqjpyhag2jw0c9")
  proPrice    String   @default("60")
  proLink     String   @default("https://www.asaas.com/c/6np0bp37c91vfla6")
  elitePrice  String   @default("100")
  eliteLink   String   @default("https://www.asaas.com/c/sql5glydf5g3gvxs")
}