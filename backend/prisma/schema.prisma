// Configuração para PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String    @default("")
  
  role         String    @default("STUDENT") 
  status       String    @default("Ativo") 
  
  phone        String?
  age          String?
  gender       String?   @default("Não informado") // <-- NOVO CAMPO: Sexo/Gênero para a IA
  weight       String?
  height       String?
  goal         String?   @default("Saúde e Condicionamento")
  level        String?   @default("Intermediário") 
  
  anamnese     String?   @db.Text 
  restricoes   String?   @db.Text 
  notes        String?   @db.Text
  avatar       String?   @db.Text
  streak       Int       @default(0)
  
  resetToken   String?
  resetExpires DateTime?

  plano          String    @default("GRATIS")
  planExpiresAt  DateTime? 
  iaUsadaMes     Int       @default(0)
  price          String?   
  
  brandName    String?
  brandColor   String?   @default("#2563eb")
  brandLogo    String?   @db.Text

  trainerId    Int?
  trainer      User?     @relation("TrainerToStudent", fields: [trainerId], references: [id], onDelete: SetNull)
  alunos       User[]    @relation("TrainerToStudent")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  history      WorkoutHistory[]
  workouts     WorkoutTemplate[]

  @@index([trainerId])
  @@index([email])    
}

model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  title       String     
  duration    String?    @default("4 Semanas")
  dayOfWeek   String?    @default("Geral")
  pdfUrl      String?    @db.Text 
  
  userId      Int?       
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exercises   Exercise[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Exercise {
  id            Int             @id @default(autoincrement())
  ficha         String?         @default("Treino Diário") // Separa o dia no PDF
  name          String
  sets          String          
  reps          String?
  weight        String?         
  rest          String?
  technical_tip String?         @db.Text
  youtubeId     String?
  
  isConjugado   Boolean         @default(false)
  conjugadoCom  String?         
  
  workoutId     Int
  workout       WorkoutTemplate @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
}

model WorkoutHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutName String
  rating      Int?     
  comment     String?  @db.Text
  completedAt DateTime @default(now())

  @@index([userId])
}

model SystemConfig {
  id           Int      @id @default(1)
  maintenance  Boolean  @default(false) 
  promoActive  Boolean  @default(false)
  promoTitle   String?  @default("🔥 OFERTA DE LANÇAMENTO 🔥")
  startPrice   String   @default("30")
  proPrice     String   @default("60")
  elitePrice   String   @default("100")
}