// Este é o ficheiro de configuração da sua Base de Dados configurado para PostgreSQL (Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   @default("") 
  role      String   @default("STUDENT") 
  streak    Int      @default(0)         
  status    String   @default("Ativo")   
  
  // --- CAMPOS DO PERFIL DO ALUNO / PERSONAL ---
  phone     String?
  age       String?
  weight    String?
  height    String?
  goal      String?  @default("Hipertrofia")
  notes     String?
  avatar    String?  @db.Text

  // --- RECUPERAÇÃO DE PALAVRA-PASSE ---
  resetToken   String?
  resetExpires DateTime?

  // --- CAMPOS DO SAAS ---
  plano      String   @default("GRATIS")
  iaUsadaMes Int      @default(0)

  // --- WHITE LABEL (Apenas para Plano Elite) ---
  brandName  String?
  brandColor String?
  brandLogo  String?  @db.Text

  // --- RELACIONAMENTOS SAAS ---
  trainerId Int?
  trainer   User?    @relation("TrainerToStudent", fields: [trainerId], references: [id])
  alunos    User[]   @relation("TrainerToStudent")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  history   WorkoutHistory[]
  workouts  WorkoutTemplate[] 
}

model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  title       String
  duration    String
  dayOfWeek   String?    @default("Segunda") 
  
  userId      Int?       
  user        User?      @relation(fields: [userId], references: [id])
  
  exercises   Exercise[]
}

model Exercise {
  id          Int      @id @default(autoincrement())
  name        String
  sets        String   
  weight      String   
  youtubeId   String?  
  
  isConjugado  Boolean  @default(false)
  conjugadoCom String? 
  
  workoutId   Int
  workout     WorkoutTemplate @relation(fields: [workoutId], references: [id], onDelete: Cascade) 
}

model WorkoutHistory {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  workoutName String
  rating      Int?
  comment     String?
  completedAt DateTime @default(now()) 
}

// ==========================================
// NOVO: CONFIGURAÇÕES GERAIS DO SISTEMA (PROMOÇÕES)
// ==========================================
model SystemConfig {
  id          Int      @id @default(1)
  promoActive Boolean  @default(false)
  promoTitle  String   @default("🔥 OFERTA DE LANÇAMENTO 🔥")
  startPrice  String   @default("30")
  startLink   String   @default("")
  proPrice    String   @default("60")
  proLink     String   @default("")
  elitePrice  String   @default("100")
  eliteLink   String   @default("")
}