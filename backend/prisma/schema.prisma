// Configuração para PostgreSQL (Neon)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// MODELO DE USUÁRIO (Hiearquia SaaS)
// ==========================================
model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String    @default("")
  
  // Níveis: SUPERADMIN (Dono), ADMIN (Personal), STUDENT (Aluno)
  role         String    @default("STUDENT") 
  status       String    @default("Ativo") // Ativo, Bloqueado, Inadimplente
  
  // Dados Biométricos (Contexto para EvoIntelligence™)
  phone        String?
  age          String?
  weight       String?
  height       String?
  goal         String?   @default("Hipertrofia")
  level        String?   @default("Intermediário") 
  
  // Prontuário Técnico
  anamnese     String?   @db.Text 
  restricoes   String?   @db.Text // Ex: "Hérnia L4-L5, Condromalácia"
  
  notes        String?   @db.Text
  avatar       String?   @db.Text
  streak       Int       @default(0)
  
  // Segurança
  resetToken   String?
  resetExpires DateTime?

  // Lógica de Assinatura e Financeiro (SaaS)
  plano          String    @default("GRATIS") // GRATIS, START, PRO, ELITE
  planExpiresAt  DateTime? 
  iaUsadaMes     Int       @default(0)
  price          String?   // NOVO: Valor cobrado daquele aluno específico (Gestão Financeira)
  
  // White Label (Exclusivo ELITE)
  brandName    String?
  brandColor   String?   @default("#2563eb")
  brandLogo    String?   @db.Text

  // Relacionamentos (Auto-relacionamento para hiearquia)
  trainerId    Int?
  trainer      User?     @relation("TrainerToStudent", fields: [trainerId], references: [id])
  alunos       User[]    @relation("TrainerToStudent")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  history      WorkoutHistory[]
  workouts     WorkoutTemplate[]

  @@index([trainerId]) // Otimiza a busca de alunos por personal
  @@index([email])     // Otimiza o login
}

// ==========================================
// MODELO DE FICHA DE TREINO
// ==========================================
model WorkoutTemplate {
  id          Int        @id @default(autoincrement())
  title       String     
  duration    String?    @default("60 min")
  dayOfWeek   String?    @default("Segunda")
  pdfUrl      String?    @db.Text 
  
  userId      Int?       
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exercises   Exercise[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId]) // Otimiza a abertura do app do aluno
}

// ==========================================
// MODELO DE EXERCÍCIO
// ==========================================
model Exercise {
  id           Int             @id @default(autoincrement())
  name         String
  sets         String          
  weight       String          
  youtubeId    String?
  
  // Lógica de Bi-set / Tri-set
  isConjugado  Boolean         @default(false)
  conjugadoCom String?         
  
  workoutId    Int
  workout      WorkoutTemplate @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
}

// ==========================================
// HISTÓRICO E MÉTRICAS DE ADESÃO
// ==========================================
model WorkoutHistory {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  workoutName  String
  rating       Int?     
  comment      String?  @db.Text
  
  completedAt  DateTime @default(now())

  @@index([userId])
}

// ==========================================
// PAINEL DE CONTROLE GLOBAL (SUPERADMIN)
// ==========================================
model SystemConfig {
  id           Int      @id @default(1)
  maintenance  Boolean  @default(false) 
  promoActive  Boolean  @default(false)
  promoTitle   String?  @default("🔥 OFERTA DE LANÇAMENTO 🔥")
  
  // Gestão de Preços SaaS
  startPrice   String   @default("30")
  proPrice     String   @default("60")
  elitePrice   String   @default("100")
}